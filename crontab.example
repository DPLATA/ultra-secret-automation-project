# Daily MLB pitcher pipeline — single job.
#
# Install with:   crontab -e   then paste the line below, edited for your paths.
# View installed: crontab -l
#
# Replace REPO with the absolute path to this repo, PYBIN with the venv python
# (e.g. /Users/you/.../REPO/.venv/bin/python).
#
# daily_run.py both builds and uploads (uploads drain pending under YouTube's
# daily quota — 3 longs + 3 shorts by default). Use --skip-upload for build-only.

0 9 * * * cd REPO && PYBIN daily_run.py >> logs/cron.log 2>&1

# Concrete example (edit and uncomment):
# 0 9 * * * cd /Users/silverboi/Documents/GitHub/ultra-secret-automation-project && /Users/silverboi/Documents/GitHub/ultra-secret-automation-project/.venv/bin/python daily_run.py >> logs/cron.log 2>&1

# --- MLB Sims static site (separate job) ---
# Runs at 9am ET each day:
#   1. Pull all completed games through last night
#   2. Re-compute team strengths
#   3. Simulate today's slate
#   4. Re-render the static site
#   5. Push rendered HTML to the public mlb-sims-site repo (Cloudflare Pages auto-deploys on push)
#
# Use `&&` so deploy only runs when the pipeline exits 0.
# Override SIM_SITE_REPO if your public site checkout is not at ~/mlb-sims-site.

0 9 * * * cd REPO && (PYBIN -m sim_site.daily_run && bash sim_site/deploy.sh) >> logs/sim_site_cron.log 2>&1

# Concrete example (edit and uncomment):
# 0 9 * * * cd /Users/silverboi/Documents/GitHub/ultra-secret-automation-project && (/Users/silverboi/Documents/GitHub/ultra-secret-automation-project/.venv/bin/python -m sim_site.daily_run && bash sim_site/deploy.sh) >> logs/sim_site_cron.log 2>&1
